# ── Firebase / Sync — NEVER commit these ─────────────────────────────────────
sync/.fernet_key
sync/service_key.enc
sync/firebase_config.json
serviceAccountKey.json
*.enc

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── PyInstaller build artifacts ───────────────────────────────────────────────
build/
dist/
*.spec

# ── SQLite databases (local data — not for version control) ───────────────────
*.db
*.sqlite
*.sqlite3

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS files ──────────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
.test_write_access

# ── Distribution / packaging ──────────────────────────────────────────────────
*.egg-info/
.eggs/
pip-wheel-metadata/
